# Supabase Postgres. DATABASE_URL = transaction pooler (runtime queries),
# DIRECT_URL = session pooler (Prisma migrations). Get both from
# Supabase dashboard > Connect > ORM > Prisma.
DATABASE_URL=
DIRECT_URL=

# Google Cloud Console > APIs & Services > Credentials > OAuth client ID (Web application)
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google (+ prod equivalent)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Auth.js session/cookie signing secret: `openssl rand -base64 32`
AUTH_SECRET=
AUTH_TRUST_HOST=true

# Web Push (browser push notifications). Generate a pair with:
# `node -e "console.log(require('web-push').generateVAPIDKeys())"`
# NEXT_PUBLIC_ prefix is required on the public key — it's read client-side
# by the push-subscribe hook (lib/notifications/usePushSubscription.ts).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Bearer token the GitHub Actions cron workflow
# (.github/workflows/notifications-cron.yml) sends when it calls the
# internal notification routes. Generate with `openssl rand -hex 32` and set
# the exact same value as a GitHub Actions repo secret of the same name.
INTERNAL_NOTIFICATIONS_SECRET=
